#!/usr/bin/env bash
set -euo pipefail

[[ -n "${HERDR_ENV:-}" ]] || { echo "herdr-manager must run inside Herdr" >&2; exit 1; }
command -v agent-dash >/dev/null || { echo "agent-dash not installed; run: ~/agentic-coding/scripts/install-agent-dash.sh" >&2; exit 1; }
command -v otel-tui >/dev/null || { echo "otel-tui not installed; run: ~/agentic-coding/scripts/install-otel-tui.sh" >&2; exit 1; }

tab=$(herdr tab create --workspace "${HERDR_WORKSPACE_ID:?missing Herdr workspace}" --label otel-tui --no-focus)
pane=$(python3 -c 'import json, sys; print(json.load(sys.stdin)["result"]["root_pane"]["pane_id"])' <<<"$tab")
for _ in {1..100}; do
  if herdr pane process-info --pane "$pane" | python3 -c 'import json, sys; sys.exit(not bool(json.load(sys.stdin)["result"]["process_info"].get("foreground_processes")))'; then
    sleep 0.25
    herdr pane run "$pane" otel-tui
    exec agent-dash --home
  fi
  sleep 0.1
done
echo "otel-tui tab shell did not become ready" >&2
exit 1
