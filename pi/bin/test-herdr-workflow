#!/usr/bin/env bash
set -euo pipefail

root=$(mktemp -d)
trap 'rm -rf "$root"' EXIT
repo="$root/repo"
mkdir -p "$repo/openspec" "$root/bin"
printf 'schema: spec-driven\n' > "$repo/openspec/config.yaml"
git -C "$repo" init -q
git -C "$repo" config user.email test@example.com
git -C "$repo" config user.name Test
touch "$repo/README.md"
git -C "$repo" add .
git -C "$repo" commit -qm init
git -C "$repo" remote add origin "$repo"
git -C "$repo" fetch origin -q
git -C "$repo" symbolic-ref refs/remotes/origin/HEAD refs/remotes/origin/master
python3 - "$PWD/pi/herdr-workflow.toml" "$root/config.toml" "$root" <<'PY'
import sys
text = open(sys.argv[1]).read().replace('root = "~/development"', f'root = "{sys.argv[3]}"')
open(sys.argv[2], 'w').write(text)
PY

cat > "$root/bin/herdr" <<MOCK
#!/usr/bin/env bash
case "\$1 \$2" in
  "workspace create") echo '{"result":{"workspace":{"workspace_id":"w1"},"root_pane":{"pane_id":"p1"}}}' ;;
  "tab list") echo '{"result":{"tabs":[{"tab_id":"t1"}]}}' ;;
  "tab create") label="\${*: -1}"; echo "{\"result\":{\"root_pane\":{\"pane_id\":\"p-\$label\"}}}" ;;
  "pane split") echo "{\"result\":{\"pane\":{\"pane_id\":\"p-\$3-\$5\"}}}" ;;
  "agent get") seq=\$(cat "$root/agent_seq" 2>/dev/null || echo 0); echo \$(( seq + 1 )) > "$root/agent_seq"; echo "{\"result\":{\"agent\":{\"agent_status\":\"working\",\"state_change_seq\":\"\$(( seq + 1 ))\"}}}" ;;
  "pane send-text") echo '{"result":{"type":"ok"}}' ;;
  *) echo '{"result":{"type":"ok"}}' ;;
esac
MOCK
chmod +x "$root/bin/herdr"
env=(PATH="$root/bin:$PATH" HERDR_WORKFLOW_CONFIG="$root/config.toml" HERDR_WORKSPACE_ID="w-dashboard")
env "${env[@]}" pi/bin/herdr-workflow projects | python3 -c 'import json,sys; p=json.load(sys.stdin); assert p[0]["name"] == "repo"'
env "${env[@]}" pi/bin/herdr-workflow start --repo "$repo" --change test-change --ticket DDS_DHP-123 --task test --mode checkout >/dev/null
env "${env[@]}" pi/bin/herdr-workflow set-return --repo "$repo" --change test-change --workspace w-home >/dev/null
change="$repo/openspec/changes/test-change"
mkdir -p "$change/specs/core"
printf '# Proposal\n' > "$change/proposal.md"
printf '# Design\n' > "$change/design.md"
printf '%s\n' '- [ ] Implement test change' > "$change/tasks.md"
printf '# Requirements\n## Scenario: works\n' > "$change/specs/core/spec.md"
env "${env[@]}" pi/bin/herdr-workflow phase --repo "$repo" --change test-change proposed >/dev/null
traceparent=00-0123456789abcdef0123456789abcdef-0123456789abcdef-01
env "${env[@]}" TRACEPARENT="$traceparent" pi/bin/herdr-workflow apply --repo "$repo" --change test-change >/dev/null
env "${env[@]}" TRACEPARENT="$traceparent" pi/bin/herdr-workflow override-phase --repo "$repo" --change test-change paused | grep -qx paused
if env "${env[@]}" pi/bin/herdr-workflow override-phase --repo "$repo" --change test-change closed >/dev/null 2>&1; then exit 1; fi
if env "${env[@]}" pi/bin/herdr-workflow override-phase --repo "$repo" --change test-change unknown >/dev/null 2>&1; then exit 1; fi

python3 - "$repo" <<'PY'
import json, sys
from pathlib import Path
root = Path(sys.argv[1])
state = json.loads((root / '.herdr-workflow/test-change/state.json').read_text())
assert state['phase'] == 'paused'
assert state['verificationRound'] == 0
assert state['branch'] == 'feature/DDS_DHP-123-test-change'
assert state['ticketNumber'] == 'DDS_DHP-123'
assert state['returnWorkspace'] == 'w-home'
assert state['panes']['dashboard'] == 'p1'
assert state['panes']['planner'] == 'p-explore'
assert state['panes']['security-verifier'] == 'p-verify'
assert state['panes']['agents-verifier'] == 'p-p-verify-right'
assert state['panes']['test-verifier'] == 'p-p-verify-down'
assert any(json.loads(line)['event'] == 'workflow_phase_overridden' and json.loads(line)['source'] == 'apply' and json.loads(line)['target'] == 'paused' for line in (root / '.herdr-workflow/test-change/telemetry.jsonl').read_text().splitlines())
assert (root / '.herdr-workflow/test-change/request.md').read_text() == '# test-change\n\n**Ticket:** DDS_DHP-123\n\ntest\n'
handoff = json.loads((root / '.herdr-workflow/test-change/trace-context/worker.json').read_text())
assert handoff['traceparent'].startswith('00-0123456789abcdef0123456789abcdef-')
assert handoff['expiresAt'] > 0 and handoff['attributes']['herdr.role'] == 'worker'
traces = [json.loads(line) for line in (root / '.herdr-workflow/test-change/traces.jsonl').read_text().splitlines()]
assert any(item['name'] == 'workflow.workflow_phase_overridden' and item['parentSpanId'] == '0123456789abcdef' for item in traces)
PY

sync="$root/worktree"
python3 - "$repo" "$sync" <<'PY'
import json, sys
from pathlib import Path
repo, worktree = map(Path, sys.argv[1:])
state = json.loads((repo / '.herdr-workflow/test-change/state.json').read_text())
state.update(changeId='sync-change', repository=str(repo), worktree=str(worktree), phase='apply')
for root in (repo, worktree):
    path = root / '.herdr-workflow/sync-change/state.json'
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(state))
PY
env "${env[@]}" pi/bin/herdr-workflow override-phase --repo "$sync" --change sync-change paused >/dev/null
python3 - "$repo" "$sync" <<'PY'
import json, sys
from pathlib import Path
source, worktree = map(Path, sys.argv[1:])
states = [json.loads((root / '.herdr-workflow/sync-change/state.json').read_text()) for root in (source, worktree)]
assert states[0] == states[1]
assert states[0]['phase'] == 'paused'
assert states[0]['panes']['worker'] == 'p-apply'
for root in (source, worktree):
    path = root / '.herdr-workflow/sync-change/state.json'
    state = json.loads(path.read_text())
    state['phase'] = 'closed'
    path.write_text(json.dumps(state))
PY
if env "${env[@]}" pi/bin/herdr-workflow override-phase --repo "$sync" --change sync-change apply >/dev/null 2>&1; then exit 1; fi

reviews="$repo/.herdr-workflow/test-change/reviews"
mkdir -p "$reviews"
printf '%s\n' '{"recoveryId":"stale","action":"retry-verification"}' > "$reviews/recovery-plan.json"
env "${env[@]}" pi/bin/herdr-workflow recover --repo "$repo" --change test-change >/dev/null
recovery_id=$(python3 - "$repo" <<'PY'
import json, sys
from pathlib import Path
root = Path(sys.argv[1]) / '.herdr-workflow/test-change/reviews'
context = json.loads((root / 'recovery-context.json').read_text())
assert context['recoveryId']
assert context['phase'] == 'paused'
assert context['allowedActions'] == ['retry-verification']
assert not (root / 'recovery-plan.json').exists()
print(context['recoveryId'])
PY
)
printf '%s\n' '[]' > "$reviews/recovery-plan.json"
if env "${env[@]}" pi/bin/herdr-workflow apply-recovery --repo "$repo" --change test-change >/dev/null 2>&1; then exit 1; fi
printf '%s\n' '{"recoveryId":"stale","action":"retry-verification"}' > "$reviews/recovery-plan.json"
if env "${env[@]}" pi/bin/herdr-workflow apply-recovery --repo "$repo" --change test-change >/dev/null 2>&1; then exit 1; fi
printf '{"recoveryId":"%s","action":"dispatch-triage"}\n' "$recovery_id" > "$reviews/recovery-plan.json"
if env "${env[@]}" pi/bin/herdr-workflow apply-recovery --repo "$repo" --change test-change >/dev/null 2>&1; then exit 1; fi

env "${env[@]}" pi/bin/herdr-workflow verify --repo "$repo" --change test-change >/dev/null
printf '%s\n' '{"roles":{}}' > "$reviews/round-1-triage.json"
env "${env[@]}" pi/bin/herdr-workflow dispatch-verifiers --repo "$repo" --change test-change >/dev/null

python3 - "$repo" <<'PY'
import json, sys
from pathlib import Path
state = json.loads((Path(sys.argv[1]) / '.herdr-workflow/test-change/state.json').read_text())
assert state['phase'] == 'developer-review'
assert state['verificationRound'] == 1
assert state['verificationRoles'] == []
PY

env "${env[@]}" agent-dash --repo "$repo" --change test-change --json | python3 -c 'import json,sys; d=json.load(sys.stdin); assert d["state"]["phase"] == "developer-review"; assert len(d["tasks"]) == 1'
agent-dash --profile test --json | python3 -c 'import json,sys; d=json.load(sys.stdin); assert d["state"]["phase"] == "proposed"; assert len(d["tasks"]) == 5'

python3 - "$repo" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1]) / '.herdr-workflow/test-change/state.json'
state = json.loads(path.read_text())
state.update(phase='verify', verificationRound=2, verificationRoles=['quality-verifier'], verificationResults={}, testVerifierStarted=False, verificationRoleStartedAt={})
path.write_text(json.dumps(state))
(path.parent / 'reviews/round-2-triage-input.json').write_text(json.dumps({'allChangedFiles': []}))
PY
printf '%s\n' '{"type":"finding","severity":"critical","path":"README.md","line":1,"detail":"critical metadata does not override PASS"}' '{"type":"verdict","verdict":"PASS"}' > "$reviews/round-2-quality-verifier.findings.jsonl"
env "${env[@]}" pi/bin/herdr-workflow verification-result --repo "$repo" --change test-change --role quality-verifier >/dev/null
python3 - "$repo" <<'PY'
import json, sys
from pathlib import Path
root = Path(sys.argv[1]) / '.herdr-workflow/test-change'
state = json.loads((root / 'state.json').read_text())
assert state['phase'] == 'verify'
assert state['testVerifierStarted']
assert state['verificationResults']['coordinator']['verdict'] == 'PENDING'
report = (root / 'reviews/round-2-consolidated.md').read_text()
assert 'Overall verdict: PENDING' in report
assert '### quality-verifier' in report
PY
printf '%s\n' '{"type":"finding","severity":"critical","path":"README.md","line":1,"detail":"test metadata does not override PASS"}' '{"type":"verdict","verdict":"PASS"}' > "$reviews/round-2-test-verifier.findings.jsonl"
env "${env[@]}" pi/bin/herdr-workflow verification-result --repo "$repo" --change test-change --role test-verifier >/dev/null
python3 - "$repo" <<'PY'
import json, sys
from pathlib import Path
root = Path(sys.argv[1]) / '.herdr-workflow/test-change'
state = json.loads((root / 'state.json').read_text())
assert state['phase'] == 'developer-review'
report = (root / 'reviews/round-2-consolidated.md').read_text()
assert 'Overall verdict: PASS' in report
assert '### test-verifier' in report
PY

python3 - "$repo" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1]) / '.herdr-workflow/test-change/state.json'
state = json.loads(path.read_text())
state.update(phase='verify', verificationRound=3, verificationRoles=['quality-verifier'], verificationResults={}, testVerifierStarted=False, verificationRoleStartedAt={})
path.write_text(json.dumps(state))
PY
printf '%s\n' '{"type":"finding","severity":"info","path":"README.md","line":1,"detail":"info metadata does not override FAIL","fix":"fix reported issue"}' '{"type":"verdict","verdict":"FAIL"}' > "$reviews/round-3-quality-verifier.findings.jsonl"
env "${env[@]}" pi/bin/herdr-workflow verification-result --repo "$repo" --change test-change --role quality-verifier >/dev/null
python3 - "$repo" <<'PY'
import json, sys
from pathlib import Path
root = Path(sys.argv[1]) / '.herdr-workflow/test-change'
state = json.loads((root / 'state.json').read_text())
assert state['phase'] == 'fix'
assert state['verificationResults']['coordinator']['verdict'] == 'FAIL'
report = (root / 'reviews/round-3-consolidated.md').read_text()
context = (root / 'reviews/round-3-worker-fix-context.md').read_text()
assert 'Overall verdict: FAIL' in report
assert '## quality-verifier' in context
assert '[info]' in context
PY
env "${env[@]}" bun run agent-dash/src/index.tsx --repo "$repo" --change test-change --json | python3 -c 'import json,sys; d=json.load(sys.stdin); assert d["reviewHistory"][-2:] == ["round-2-consolidated.md: PASS", "round-3-consolidated.md: FAIL"]'
