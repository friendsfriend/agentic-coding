{
  "name": "agent-dash",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build": "bun install && bun run scripts/build.ts",
    "build:single": "bun install && bun run scripts/build.ts --single",
    "install:bin": "bun run scripts/install-bin.ts",
    "type-check": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@opentui/core": "0.4.2",
    "@opentui/keymap": "0.4.2",
    "@opentui/solid": "0.4.2",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
